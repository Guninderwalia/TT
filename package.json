{
  "name": "tasktango-crm",
  "version": "5.4.0",
  "description": "Enterprise HR & Employee Management Desktop Application",
  "main": "src/main/main.js",
  "homepage": "./",
  "private": true,
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1066.0",
    "bcryptjs": "^2.4.3",
    "chart.js": "^3.9.1",
    "chartjs-plugin-datalabels": "^2.2.0",
    "classnames": "^2.3.2",
    "cors": "^2.8.6",
    "date-fns": "^2.30.0",
    "express": "^5.2.1",
    "lucide-react": "^0.263.1",
    "papaparse": "^5.4.1",
    "pdfmake": "^0.2.23",
    "react": "^18.2.0",
    "react-chartjs-2": "^4.1.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.14.0",
    "sql.js": "^1.14.1",
    "sqlite": "^5.0.1",
    "sqlite3": "^6.0.1",
    "uuid": "^9.0.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "concurrently": "^8.2.0",
    "cross-env": "^10.1.0",
    "electron": "^27.0.0",
    "electron-builder": "^24.6.4",
    "electron-packager": "^17.1.2",
    "electron-rebuild": "^3.2.9",
    "react-scripts": "5.0.1",
    "wait-on": "^7.1.0"
  },
  "scripts": {
    "react-start": "cross-env PORT=3001 react-scripts start",
    "react-build": "react-scripts build",
    "electron-dev": "concurrently \"npm run react-start\" \"wait-on http://localhost:3001 && cross-env NODE_ENV=development electron .\"",
    "electron-build": "npm run react-build && electron-builder",
    "build-exe": "npm install && npm run electron-build -- --win --publish=never",
    "server-build": "react-scripts build",
    "start": "node src/server/server.js"
  },
  "build": {
    "appId": "com.tasktango.crm",
    "productName": "TaskTango",
    "files": [
      "build/**/*",
      "src/main/**/*",
      "src/db/**/*",
      "src/utils/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "**/*.node",
      "node_modules/sqlite3/**"
    ],
    "extraFiles": [
      {
        "from": "src/main",
        "to": "src/main"
      },
      {
        "from": "src/db",
        "to": "src/db"
      },
      {
        "from": "src/utils",
        "to": "src/utils"
      },
      {
        "from": "public/training-guides",
        "to": "training-guides"
      }
    ],
    "directories": {
      "buildResources": "public"
    },
    "extraMetadata": {
      "main": "src/main/main.js"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "certificateFile": null,
      "certificatePassword": null,
      "signingHashAlgorithms": [
        "sha256"
      ],
      "sign": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "TaskTango"
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
